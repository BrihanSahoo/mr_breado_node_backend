{
  "name": "mr-breado-node-backend",
  "version": "1.0.0",
  "description": "Node.js Express replica of Mr Breado Spring Boot backend with compatible endpoints.",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:init": "node src/db/init.js",
    "check:syntax": "find src test scripts -name \"*.js\" -print0 | xargs -0 -n1 node --check",
    "test": "node --test test/*.test.js",
    "migrate": "node scripts/migrate.js",
    "jobs:auto-cancel": "node scripts/runAutoCancelOnce.js"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.5",
    "nanoid": "^5.0.9",
    "razorpay": "^2.9.5",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
